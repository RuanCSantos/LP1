//Ordem alfabética
void OrdemAlfabetica(char nomes[30][30], char ordemAlfabetica[30][30], int qtdeNomes)
{
    int a, j;
    char temp[30];

    //Copia os nomes para a matriz de ordem alfabética
    for (a = 0; a < qtdeNomes; a++)
    {
        strcpy(ordemAlfabetica[a], nomes[a]);
    }
    //Ordena os nomes em ordem alfabética usando o método de bolha
    for (a = 0; a < qtdeNomes - 1; a++)
    {
        for (j = 0; j < qtdeNomes - a - 1; j++)
        {
            if (strcmp(ordemAlfabetica[j], ordemAlfabetica[j + 1]) > 0)
            {
                //Troca os nomes
                strcpy(temp, ordemAlfabetica[j]);
                strcpy(ordemAlfabetica[j], ordemAlfabetica[j + 1]);
                strcpy(ordemAlfabetica[j + 1], temp);
            }
        }
    }
}
